<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="frontend.MainController">

    <top>
        <TextField fx:id="searchField" onAction="#onSearch" promptText="Search Book" />
    </top>

    <center>

        <TableView fx:id="bookTable">

            <columns>

                <TableColumn fx:id="titleColumn" text="Title" />

                <TableColumn fx:id="authorColumn" text="Author" />

                <TableColumn fx:id="statusColumn" text="Status" />

            </columns>

        </TableView>

    </center>

    <bottom>

        <HBox spacing="10">

            <Button onAction="#onAddBook" text="Add" />

            <Button onAction="#onDeleteBook" text="Delete" />

            <Button onAction="#onBorrowBook" text="Borrow" />

            <Button onAction="#onReturnBook" text="Return" />

        </HBox>

    </bottom>

</BorderPane>
