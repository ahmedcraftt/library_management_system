<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="frontend.AddBookController">

    <TextField fx:id="titleField" promptText="Title" />
    <TextField fx:id="authorField" promptText="Author" />

    <Button onAction="#onAddBook" text="Add Book" />
</VBox>
